import pandas as pd
import numpy as np
import matplotlib
matplotlib.use('Agg')

import matplotlib.pyplot as plt
import warnings
from pathlib import Path

warnings.filterwarnings("ignore")

# ==========================================================
# PHASE 2 - EXPLORATORY DATA ANALYSIS
# Emergency Department Thesis
# ==========================================================

BASE = Path("/Users/thanmayeegali/ED_Thesis.ipynb/.vscode/Emergency_Department")
CLEAN_FILE = BASE / "triage_cleaned.csv"

# ==========================================================
# Load Data
# ==========================================================

print("\nLoading cleaned dataset...")

df = pd.read_csv(CLEAN_FILE, low_memory=False)

print(f"Loaded: {df.shape[0]:,} rows")
print(f"Columns: {df.shape[1]:,}")

# ==========================================================
# Plot 1: Admission Distribution
# ==========================================================

print("\nPlot 1: Admission Distribution")

plt.figure(figsize=(7,5))

counts = df['admitted'].value_counts().sort_index()

plt.bar(
    ['Discharged', 'Admitted'],
    counts.values
)

plt.title("Admission vs Discharge")
plt.ylabel("Patients")

for i, v in enumerate(counts.values):
    plt.text(i, v + 3000, f"{v:,}", ha='center')

plt.tight_layout()

plt.savefig(
    BASE / "plot1_admission_distribution.png",
    dpi=150
)

plt.close()

# ==========================================================
# Plot 2: ESI Distribution
# ==========================================================

print("Plot 2: ESI Distribution")

plt.figure(figsize=(7,5))

df['esi'].value_counts().sort_index().plot(
    kind='bar'
)

plt.title("ESI Distribution")
plt.xlabel("ESI Level")
plt.ylabel("Patients")

plt.tight_layout()

plt.savefig(
    BASE / "plot2_esi_distribution.png",
    dpi=150
)

plt.close()

# ==========================================================
# Plot 3: Admission Rate by ESI
# ==========================================================

print("Plot 3: Admission Rate by ESI")

plt.figure(figsize=(7,5))

esi_admit = (
    df.groupby('esi')['admitted']
      .mean() * 100
)

esi_admit.plot(kind='bar')

plt.title("Admission Rate by ESI")
plt.ylabel("Admission Rate (%)")

for i, v in enumerate(esi_admit.values):
    plt.text(i, v + 0.5, f"{v:.1f}%")

plt.tight_layout()

plt.savefig(
    BASE / "plot3_admission_by_esi.png",
    dpi=150
)

plt.close()

# ==========================================================
# Plot 4: Age Distribution
# ==========================================================

print("Plot 4: Age Distribution")

