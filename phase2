# ==========================================================
# Complexity Score
# ==========================================================

print("\nComplexity Score")

disease_cols = [
    'htn',
    'copd',
    'chrkidneydisease',
    'diabmelnoc',
    'chfnonhp'
]

available = [
    c for c in disease_cols
    if c in df.columns
]

df['complexity_score'] = (
    df[available]
    .sum(axis=1)
)

print(
    df['complexity_score']
    .describe()
)

complexity_admit = (
    df.groupby('complexity_score')
      ['admitted']
      .mean() * 100
)

print("\nAdmission Rate by Complexity")

print(complexity_admit)

complexity_admit.to_csv(
    BASE / "complexity_admission_rates.csv"
)

# ==========================================================
# Correlation Analysis
# ==========================================================

print("\nCorrelation with Admission")

important = [
    'admitted',
    'age',
    'esi',
    'n_edvisits',
    'n_admissions',
    'triage_vital_hr',
    'triage_vital_sbp',
    'triage_vital_temp'
]

existing = [
    c for c in important
    if c in df.columns
]

corr = (
    df[existing]
    .corr()['admitted']
    .sort_values(ascending=False)
)

print(corr)

corr.to_csv(
    BASE / "admission_correlations.csv"
)

from scipy.stats import chi2_contingency

print("\nChi-Square Test")

if 'esi' in df.columns:

    contingency_table = pd.crosstab(
        df['esi'],
        df['admitted']
    )

    chi2, p, dof, expected = chi2_contingency(
        contingency_table
    )

    print(f"Chi-square statistic : {chi2:.3f}")
    print(f"P-value              : {p:.8f}")

    if p < 0.05:
        print(
            "Result: Significant association between ESI and admission."
        )
    else:
        print(
            "Result: No significant association."
        )
